<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pixel & Form — Web Design Studio</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0A0A0F;
    --bg2: #111118;
    --bg3: #18181f;
    --accent: #7C6BFF;
    --accent2: #C2B8FF;
    --accent3: #2a2240;
    --text: #F0EEF8;
    --muted: #9990BB;
    --border: rgba(124,107,255,0.18);
    --card: #13131a;
    --green: #36E4A0;
    --amber: #F5B942;
    --coral: #FF6B6B;
    --font-display: 'DM Serif Display', serif;
    --font-body: 'DM Sans', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--font-body); font-size: 16px; line-height: 1.7; overflow-x: hidden; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  /* --- NAV --- */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5vw; height: 68px;
    background: rgba(10,10,15,0.85); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo { font-family: var(--font-display); font-size: 1.35rem; letter-spacing: -0.5px; }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 2rem; font-size: 0.88rem; color: var(--muted); }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    font-size: 0.85rem; font-weight: 500; padding: 9px 22px;
    background: var(--accent); color: #fff; border-radius: 100px;
    transition: opacity 0.2s;
  }
  .nav-cta:hover { opacity: 0.85; }
  .nav-admin-btn {
    font-size: 0.8rem; color: var(--muted); padding: 6px 14px;
    border: 1px solid var(--border); border-radius: 100px;
    cursor: pointer; background: none; margin-right: 10px;
    transition: all 0.2s;
  }
  .nav-admin-btn:hover { color: var(--accent); border-color: var(--accent); }

  /* --- SECTIONS --- */
  section { padding: 100px 5vw; }
  .section-label { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
  h1 { font-family: var(--font-display); font-size: clamp(2.8rem, 6vw, 5rem); line-height: 1.08; letter-spacing: -1px; }
  h2 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.2rem); line-height: 1.12; letter-spacing: -0.5px; }
  h3 { font-size: 1.1rem; font-weight: 600; }

  /* --- HERO --- */
  #hero {
    min-height: 100vh; display: flex; flex-direction: column;
    justify-content: center; padding-top: 120px; padding-bottom: 80px;
    position: relative; overflow: hidden;
  }
  .hero-orb {
    position: absolute; border-radius: 50%; pointer-events: none; filter: blur(80px);
  }
  .orb1 { width: 500px; height: 500px; background: rgba(124,107,255,0.18); top: -100px; right: -100px; }
  .orb2 { width: 300px; height: 300px; background: rgba(54,228,160,0.1); bottom: 50px; left: -50px; }
  .hero-eyebrow { display: flex; align-items: center; gap: 10px; margin-bottom: 28px; }
  .hero-eyebrow span { font-size: 0.8rem; color: var(--muted); }
  .hero-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); }
  .hero-title { max-width: 760px; margin-bottom: 28px; }
  .hero-title em { font-style: italic; color: var(--accent2); }
  .hero-sub { color: var(--muted); font-size: 1.08rem; max-width: 520px; line-height: 1.75; margin-bottom: 44px; }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary {
    padding: 14px 32px; background: var(--accent); color: #fff; border-radius: 100px;
    font-weight: 500; font-size: 0.95rem; border: none; cursor: pointer; transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-outline {
    padding: 14px 32px; background: transparent; color: var(--text);
    border: 1px solid var(--border); border-radius: 100px;
    font-weight: 500; font-size: 0.95rem; cursor: pointer; transition: all 0.2s;
  }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }
  .hero-stats { display: flex; gap: 48px; margin-top: 64px; }
  .hero-stat .num { font-family: var(--font-display); font-size: 2.4rem; color: var(--text); }
  .hero-stat .lbl { font-size: 0.8rem; color: var(--muted); margin-top: 4px; }

  /* --- MARQUEE --- */
  .marquee-wrap { overflow: hidden; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 16px 0; }
  .marquee-track { display: flex; gap: 60px; animation: marquee 22s linear infinite; white-space: nowrap; }
  .marquee-track span { font-size: 0.82rem; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; }
  .marquee-track span b { color: var(--accent); }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* --- SERVICES --- */
  #services { background: var(--bg2); }
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 52px; }
  .service-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 16px;
    padding: 32px; transition: border-color 0.2s, transform 0.2s;
    position: relative; overflow: hidden;
  }
  .service-card:hover { border-color: var(--accent); transform: translateY(-4px); }
  .service-icon {
    width: 44px; height: 44px; border-radius: 12px; background: var(--accent3);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.35rem; margin-bottom: 20px;
  }
  .service-card h3 { margin-bottom: 10px; }
  .service-card p { color: var(--muted); font-size: 0.9rem; line-height: 1.7; }
  .service-price { margin-top: 22px; font-size: 0.82rem; color: var(--accent2); font-weight: 500; }

  /* --- WORK / PORTFOLIO --- */
  #work {}
  .work-header { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 20px; margin-bottom: 52px; }
  .work-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; }
  .work-card {
    border-radius: 16px; overflow: hidden; background: var(--card);
    border: 1px solid var(--border); cursor: pointer; transition: transform 0.25s, border-color 0.25s;
  }
  .work-card:hover { transform: translateY(-6px); border-color: var(--accent); }
  .work-thumb {
    aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;
    font-size: 3rem; position: relative; overflow: hidden;
  }
  .work-thumb-overlay {
    position: absolute; inset: 0; background: rgba(124,107,255,0.12);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.25s;
  }
  .work-card:hover .work-thumb-overlay { opacity: 1; }
  .work-thumb-overlay span { font-size: 0.85rem; color: #fff; background: var(--accent); padding: 8px 20px; border-radius: 100px; }
  .work-info { padding: 22px 24px; }
  .work-info h3 { margin-bottom: 6px; }
  .work-info p { color: var(--muted); font-size: 0.88rem; margin-bottom: 14px; }
  .work-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag { font-size: 0.75rem; padding: 4px 12px; background: var(--accent3); color: var(--accent2); border-radius: 100px; }

  /* --- PROCESS --- */
  #process { background: var(--bg2); }
  .process-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; margin-top: 52px; position: relative; }
  .process-step { text-align: center; padding: 32px 20px; }
  .process-num {
    font-family: var(--font-display); font-size: 3rem; color: var(--accent3);
    line-height: 1; margin-bottom: 16px; -webkit-text-stroke: 1px var(--accent);
  }
  .process-step h3 { margin-bottom: 8px; }
  .process-step p { color: var(--muted); font-size: 0.88rem; }

  /* --- TESTIMONIALS --- */
  #testimonials {}
  .testimonials-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 52px; }
  .testi-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 28px;
  }
  .testi-stars { color: var(--amber); font-size: 0.85rem; margin-bottom: 16px; }
  .testi-card blockquote { color: var(--muted); font-size: 0.92rem; line-height: 1.75; margin-bottom: 22px; font-style: italic; }
  .testi-author { display: flex; align-items: center; gap: 12px; }
  .testi-avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.85rem; }
  .testi-author-info strong { display: block; font-size: 0.88rem; }
  .testi-author-info span { font-size: 0.78rem; color: var(--muted); }

  /* --- CTA --- */
  #cta {
    background: var(--bg2); text-align: center; padding: 100px 5vw;
  }
  #cta h2 { margin-bottom: 18px; }
  #cta p { color: var(--muted); max-width: 480px; margin: 0 auto 40px; }
  .contact-form { max-width: 520px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .contact-form input, .contact-form textarea, .contact-form select {
    width: 100%; padding: 13px 16px; background: var(--bg3); border: 1px solid var(--border);
    border-radius: 10px; color: var(--text); font-family: var(--font-body); font-size: 0.9rem;
    transition: border-color 0.2s; outline: none;
  }
  .contact-form input:focus, .contact-form textarea:focus, .contact-form select:focus { border-color: var(--accent); }
  .contact-form textarea { min-height: 110px; resize: vertical; }
  .contact-form select option { background: var(--bg3); }

  /* --- FOOTER --- */
  footer {
    border-top: 1px solid var(--border); padding: 40px 5vw;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: gap;
    gap: 20px;
  }
  footer .logo { font-family: var(--font-display); font-size: 1.2rem; }
  footer .logo span { color: var(--accent); }
  footer nav a { font-size: 0.82rem; color: var(--muted); margin-left: 24px; }
  footer nav a:hover { color: var(--text); }
  .footer-copy { font-size: 0.78rem; color: var(--muted); }

  /* ========================
     ADMIN PANEL
  ======================== */
  #admin-overlay {
    display: none; position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(6px);
  }
  #admin-panel {
    position: fixed; top: 0; right: -560px; width: 560px; height: 100vh;
    background: #0e0e14; border-left: 1px solid var(--border);
    z-index: 1001; overflow-y: auto; transition: right 0.35s cubic-bezier(.4,0,.2,1);
    display: flex; flex-direction: column;
  }
  #admin-panel.open { right: 0; }
  #admin-overlay.open { display: block; }

  /* Login gate */
  #admin-login {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    flex: 1; padding: 48px 40px;
  }
  .admin-login-logo { font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 8px; }
  .admin-login-logo span { color: var(--accent); }
  .admin-login-sub { color: var(--muted); font-size: 0.85rem; margin-bottom: 40px; }
  .admin-login-form { width: 100%; display: flex; flex-direction: column; gap: 14px; }
  .admin-input {
    width: 100%; padding: 12px 16px; background: var(--bg3);
    border: 1px solid var(--border); border-radius: 10px;
    color: var(--text); font-family: var(--font-body); font-size: 0.9rem; outline: none;
    transition: border-color 0.2s;
  }
  .admin-input:focus { border-color: var(--accent); }
  .admin-login-err { font-size: 0.8rem; color: var(--coral); display: none; margin-top: -6px; }
  .admin-hint { font-size: 0.75rem; color: var(--muted); margin-top: 10px; text-align: center; }

  /* Admin Dashboard */
  #admin-dashboard { display: none; flex: 1; flex-direction: column; }
  .admin-topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 28px; border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .admin-topbar h2 { font-size: 1rem; font-weight: 600; }
  .admin-close {
    background: none; border: none; color: var(--muted); font-size: 1.3rem;
    cursor: pointer; width: 32px; height: 32px; display: flex; align-items: center;
    justify-content: center; border-radius: 8px; transition: all 0.2s;
  }
  .admin-close:hover { background: var(--bg3); color: var(--text); }
  .admin-tabs { display: flex; border-bottom: 1px solid var(--border); padding: 0 28px; flex-shrink: 0; }
  .admin-tab {
    padding: 14px 18px; font-size: 0.83rem; color: var(--muted); cursor: pointer;
    border-bottom: 2px solid transparent; transition: all 0.2s; margin-bottom: -1px;
  }
  .admin-tab.active { color: var(--accent); border-color: var(--accent); }
  .admin-content { padding: 24px 28px; flex: 1; overflow-y: auto; }
  .admin-tab-panel { display: none; }
  .admin-tab-panel.active { display: block; }

  /* Admin sections */
  .admin-section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 16px; }
  .admin-card {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 12px;
    padding: 20px 22px; margin-bottom: 14px;
  }
  .admin-card h4 { font-size: 0.9rem; font-weight: 600; margin-bottom: 4px; }
  .admin-card p { font-size: 0.8rem; color: var(--muted); }
  .admin-field { margin-bottom: 14px; }
  .admin-field label { display: block; font-size: 0.78rem; color: var(--muted); margin-bottom: 6px; }
  .admin-field input, .admin-field textarea, .admin-field select {
    width: 100%; padding: 10px 13px; background: var(--bg);
    border: 1px solid var(--border); border-radius: 8px;
    color: var(--text); font-family: var(--font-body); font-size: 0.85rem; outline: none;
    transition: border-color 0.2s;
  }
  .admin-field input:focus, .admin-field textarea:focus, .admin-field select:focus { border-color: var(--accent); }
  .admin-field textarea { min-height: 80px; resize: vertical; }
  .admin-field select option { background: var(--bg); }
  .admin-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .btn-save {
    padding: 10px 22px; background: var(--accent); color: #fff; border: none;
    border-radius: 8px; font-size: 0.85rem; font-weight: 500; cursor: pointer; transition: opacity 0.2s;
  }
  .btn-save:hover { opacity: 0.85; }
  .btn-danger {
    padding: 8px 16px; background: transparent; color: var(--coral);
    border: 1px solid rgba(255,107,107,0.3); border-radius: 8px;
    font-size: 0.8rem; cursor: pointer; transition: all 0.2s;
  }
  .btn-danger:hover { background: rgba(255,107,107,0.08); }
  .stats-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 24px; }
  .stat-card {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 10px;
    padding: 16px; text-align: center;
  }
  .stat-card .val { font-family: var(--font-display); font-size: 1.8rem; color: var(--text); }
  .stat-card .lbl { font-size: 0.72rem; color: var(--muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.06em; }
  .project-list-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 0; border-bottom: 1px solid var(--border); gap: 12px;
  }
  .project-list-item:last-child { border-bottom: none; }
  .proj-info h4 { font-size: 0.88rem; font-weight: 500; }
  .proj-info span { font-size: 0.75rem; color: var(--muted); }
  .proj-actions { display: flex; gap: 8px; flex-shrink: 0; }
  .btn-edit {
    padding: 6px 14px; background: var(--accent3); color: var(--accent2);
    border: none; border-radius: 6px; font-size: 0.78rem; cursor: pointer; transition: opacity 0.2s;
  }
  .btn-edit:hover { opacity: 0.8; }
  .badge { display: inline-flex; padding: 3px 10px; border-radius: 100px; font-size: 0.72rem; font-weight: 500; }
  .badge-green { background: rgba(54,228,160,0.12); color: var(--green); }
  .badge-amber { background: rgba(245,185,66,0.12); color: var(--amber); }
  .msg-item { padding: 14px 0; border-bottom: 1px solid var(--border); }
  .msg-item:last-child { border-bottom: none; }
  .msg-item h4 { font-size: 0.88rem; font-weight: 500; margin-bottom: 4px; }
  .msg-item p { font-size: 0.8rem; color: var(--muted); }
  .msg-item .msg-meta { display: flex; gap: 10px; align-items: center; margin-top: 8px; }
  .admin-logout {
    background: none; border: none; color: var(--muted); font-size: 0.8rem;
    cursor: pointer; padding: 6px 14px; border-radius: 6px; transition: all 0.2s;
  }
  .admin-logout:hover { color: var(--coral); }
  .save-toast {
    position: fixed; bottom: 28px; right: 28px; background: var(--accent);
    color: #fff; padding: 12px 24px; border-radius: 100px; font-size: 0.85rem;
    font-weight: 500; z-index: 2000; transform: translateY(80px); opacity: 0;
    transition: all 0.3s;
  }
  .save-toast.show { transform: translateY(0); opacity: 1; }

  /* Responsive */
  @media (max-width: 700px) {
    .nav-links { display: none; }
    .hero-stats { gap: 24px; flex-wrap: wrap; }
    .form-row { grid-template-columns: 1fr; }
    #admin-panel { width: 100%; right: -100%; }
    .admin-row { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Page transitions */
  section { opacity: 1; transform: translateY(0); transition: opacity 0.5s, transform 0.5s; }

  /* Gradient text utility */
  .grad { background: linear-gradient(135deg, var(--accent2), var(--green)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
</style>
</head>
<body>

<!-- NAVIGATION -->
<nav>
  <div class="nav-logo">Pixel<span>&</span>Form</div>
  <div class="nav-links">
    <a href="#services">Services</a>
    <a href="#work">Work</a>
    <a href="#process">Process</a>
    <a href="#testimonials">Clients</a>
    <a href="#cta">Contact</a>
  </div>
  <div style="display:flex;align-items:center;">
    <button class="nav-admin-btn" onclick="openAdmin()">Admin ↗</button>
    <a href="#cta" class="nav-cta">Start a project</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-orb orb1"></div>
  <div class="hero-orb orb2"></div>
  <div class="hero-eyebrow">
    <div class="hero-dot"></div>
    <span>Open for new projects · 2025</span>
  </div>
  <div class="hero-title">
    <h1>We craft digital<br>experiences that<br><em>actually convert</em></h1>
