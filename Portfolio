    <span>UI Design</span><span>·</span><span>Web Development</span><span>·</span>
    <span>Brand Identity</span><span>·</span><span>E-commerce</span><span>·</span>
    <span>Motion Design</span><span>·</span><span>SEO Optimization</span><span>·</span>
    <span>CMS Integration</span><span>·</span><span>React & Next.js</span><span>·</span>
  </div>
</div>

<!-- SERVICES -->
<section id="services">
  <div class="section-label">What we do</div>
  <h2>Services built<br>for growth</h2>
  <div class="services-grid" id="services-grid">
    <div class="service-card">
      <div class="service-icon">🎨</div>
      <h3>UI / UX Design</h3>
      <p>Pixel-perfect interfaces crafted with Figma. Every screen is both beautiful and intuitive — tested with real users.</p>
      <div class="service-price">Starting at ₹25,000</div>
    </div>
    <div class="service-card">
      <div class="service-icon">💻</div>
      <h3>Website Development</h3>
      <p>Custom-coded, blazing-fast websites. React, Next.js, or plain HTML — we match the stack to your needs.</p>
      <div class="service-price">Starting at ₹40,000</div>
    </div>
    <div class="service-card">
      <div class="service-icon">🛍️</div>
      <h3>E-commerce Stores</h3>
      <p>Shopify and WooCommerce stores designed to convert. Optimised checkout flows that reduce cart abandonment.</p>
      <div class="service-price">Starting at ₹55,000</div>
    </div>
    <div class="service-card">
      <div class="service-icon">✦</div>
