function saveSettings() {
  siteSettings.name = document.getElementById('s-name').value;
  siteSettings.loc = document.getElementById('s-loc').value;
  siteSettings.h1 = document.getElementById('s-h1').value;
  siteSettings.h2 = document.getElementById('s-h2').value;
  siteSettings.clients = parseInt(document.getElementById('s-clients').value) || 86;
  siteSettings.projects = parseInt(document.getElementById('s-projects').value) || 140;
  siteSettings.years = parseInt(document.getElementById('s-years').value) || 7;
  siteSettings.email = document.getElementById('s-email').value;
  siteSettings.phone = document.getElementById('s-phone').value;
  // Apply live
  document.getElementById('stat-clients').textContent = siteSettings.clients + '+';
  document.getElementById('stat-projects').textContent = siteSettings.projects + '+';
  document.getElementById('stat-years').textContent = siteSettings.years;
  showToast('Settings saved');
}

function showAddProject() {
  document.getElementById('add-project-form').style.display = 'block';
  document.getElementById('np-name').focus();
}

function addProject() {
  const name = document.getElementById('np-name').value.trim();
  if (!name) return;
  const p = {
    id: Date.now(),
    name,
    desc: document.getElementById('np-desc').value,
    cat: document.getElementById('np-cat').value,
    status: document.getElementById('np-status').value
  };
  projects.push(p);
  document.getElementById('add-project-form').style.display = 'none';
  document.getElementById('np-name').value = '';
  document.getElementById('np-desc').value = '';
  renderProjects();
  showToast('Project added');
}

function deleteProject(id) {
  if (confirm('Delete this project?')) {
    projects = projects.filter(p => p.id !== id);
    renderProjects();
    showToast('Project deleted');
  }
}

function editProject(id) {
  const p = projects.find(x => x.id === id);
  if (!p) return;
  const newName = prompt('Edit project name:', p.name);
  if (newName && newName.trim()) { p.name = newName.trim(); renderProjects(); showToast('Project updated'); }
}

// ===== CONTACT FORM =====
function submitContact() {
  const name = document.getElementById('cf-name').value.trim();
  const email = document.getElementById('cf-email').value.trim();
  const service = document.getElementById('cf-service').value;
  const msg = document.getElementById('cf-message').value.trim();
  if (!name || !email || !msg) { alert('Please fill in name, email, and message.'); return; }
  messages.unshift({
    id: Date.now(), name, email, service: service || 'General enquiry',
    budget: document.getElementById('cf-budget').value || '',
    msg, time: 'Just now', read: false
  });
  document.getElementById('cf-name').value = '';
  document.getElementById('cf-email').value = '';
  document.getElementById('cf-message').value = '';
  document.getElementById('cf-budget').value = '';
  document.getElementById('cf-service').value = '';
  showToast('Message sent! We\'ll reply within 24 hours.');
}

// ===== TOAST =====
function showToast(msg='Changes saved') {
  const t = document.getElementById('toast');
  t.textContent = '✓ ' + msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ===== SCROLL REVEAL =====
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: 0.08 });
document.querySelectorAll('section').forEach(s => {
  s.style.opacity = '0'; s.style.transform = 'translateY(32px)';
  observer.observe(s);
});
// Immediately show hero
document.getElementById('hero').style.opacity = '1';
document.getElementById('hero').style.transform = 'translateY(0)';
</script>
