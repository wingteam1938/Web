// ===== COUNT-UP ANIMATION =====
function countUp(el, target, suffix='') {
  let start = 0, dur = 1600, step = 16;
  let inc = target / (dur / step);
  let t = setInterval(() => {
    start = Math.min(start + inc, target);
    el.textContent = Math.round(start) + suffix;
    if (start >= target) clearInterval(t);
  }, step);
}

window.addEventListener('load', () => {
  setTimeout(() => {
    countUp(document.getElementById('stat-clients'), 86, '+');
    countUp(document.getElementById('stat-projects'), 140, '+');
    countUp(document.getElementById('stat-years'), 7);
